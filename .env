# ============================================================================
# Performance Gate - configuration
# Edit a value here, save, and re-run. No command-line flags needed.
# Lines starting with # are ignored. Format is KEY=value.
#
# SECURITY NOTE: for safety, this .env is only read from the agent's own folder
# (this file) - never from the code being reviewed - and only the three keys
# below are honoured. Anything that decides WHERE data goes (the model endpoint,
# host, backend, tokens) is intentionally NOT settable here, so a scanned repo
# can never redirect the tool off your network. Those stay operator-only (set as
# real environment variables on the runner if you ever need them).
# ============================================================================

# Which local model to use for Stage 2 (must be one you have in `ollama list`).
# Examples: llama3.1:latest | gemma3:12b | llama3:latest | qwen2.5-coder:7b
PERF_GATE_MODEL=llama3.1:latest

# Turn the local model OFF and run static rules only:  1/true/yes = off, 0/false = on
PERF_GATE_LLM_DISABLED=0

# Build fails when a finding at or above this severity is found.
# CRITICAL | HIGH | MEDIUM | LOW | INFO | NONE
PERF_GATE_FAIL_ON=HIGH

# ----------------------------------------------------------------------------
# Operator-only (NOT read from this file - set as real env vars on the runner):
#   PERF_GATE_BACKEND=ollama|openai   OLLAMA_HOST=...   PERF_GATE_BASE_URL=...
#   PERF_GATE_API_KEY=...             (only needed for the openai backend)
# ----------------------------------------------------------------------------
